name = "cn-cheems/moonnavkit"

version = "0.3.0"

readme = "README.mbt.md"

repository = "https://github.com/cn-cheems/moonnavkit"

license = "Apache-2.0"

keywords = [
  "pathfinding",
  "astar",
  "clearance",
  "cost-map",
  "dstar-lite",
  "dynamic-pathfinding",
  "flow-field",
  "graph",
  "grid",
  "routing",
  "visualization",
]

description = "Static and dynamic weighted path planning, clearance-aware routing, flow fields, path compression, and search visualization for MoonBit."
